## Copy this file to .env.local and fill with your Supabase values

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older naming still works:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side role key for admin/server operations
SUPABASE_SERVICE_ROLE_KEY=
# Legacy alias still supported
# SUPABASE_SECRET_KEY=

# Public app URL used for redirects/callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Groq icon-agent resolver (local + backend-safe)
GROQ_API_KEY=your_groq_api_key
GROQ_ICON_AGENT_MODEL=llama-3.1-8b-instant
GROQ_ICON_AGENT_TEMPERATURE=0.2
GROQ_ICON_AGENT_TIMEOUT_MS=9000
