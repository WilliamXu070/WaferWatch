addfdtd;
set('dimension','3D');
set('index',1);
set('x', Device_length/2 );
set('x span', Device_length);
set('y', 0);
set('y span', 7e-6);
set('z', 0.3e-6);
set('z span', 3e-6);
set('mesh type','auto non-uniform');
set('mesh accuracy',2);
set('mesh refinement','conformal variant 0');
set('x min bc','PML');
set('x max bc','PML');
set('y min bc','PML');
set('y max bc','PML');
set('z min bc','PML');
set('z max bc','PML');
set('auto scale pml parameters',1);
set('snap pec to yee cell boundary',1);
set('pml layers', 16);
set('simulation time',3e-12);
set('background material','SiO2 (Glass) - Palik');
setglobalsource('wavelength start',wavelength);
setglobalsource('wavelength stop',wavelength);
#SOURCE
addmode;
set('direction','Forward');
set('injection axis','x-axis');
set('y',0);
set('y span',5e-6);
set('x',1e-6);
set('z',0.3e-6);
set('z span',5e-6);
set('override global source settings',false);
set('mode selection','fundamental TE mode');
set('auto update',1);
set('override global source settings',1);
set('wavelength start',wavelength);
set('wavelength stop',wavelength);


#addmesh;
#set('x',Device_length / 2);
#set('x span',Length + 3e-6);
#set('y',0);
#set('y span',6e-6);
#set('z',0.3e-6);
#set('z span',4e-6);
#set('dx',mesh);
#set('dy',mesh);
#set('dz',mesh);

addpower;
set('name','opt_fields');
set('monitor type','3D');
set('x',WG_length + Length + Second_length/2);
set('x span',Second_length);
set('y',0);
set('y span',7e-6);
set('z',0.3e-6);
set('z span',3e-6);


addpower;
set('name','fom_up');
set('monitor type','2D X-normal');
set('x',WG_length + Length + Second_length + 0.5e-6);
set('y',Sep/2);
set('y span',2.5e-6);
set('z',0.3e-6);
set('z span',3e-6);

addpower;
set('name','fom_down');
set('monitor type','2D X-normal');
set('x',WG_length + Length + Second_length + 0.5e-6);
set('y',-Sep/2);
set('y span',2.5e-6);
set('z',0.3e-6);
set('z span',3e-6);

addpower;
set('name','fom_up2');
set('monitor type','2D X-normal');
set('x',WG_length + Length + Second_length + 1.2e-6);
set('y',Sep/2);
set('y span',2.5e-6);
set('z',0.3e-6);
set('z span',3e-6);

addpower;
set('name','fom_down2');
set('monitor type','2D X-normal');
set('x',WG_length + Length + Second_length + 1.2e-6);
set('y',-Sep/2);
set('y span',2.5e-6);
set('z',0.3e-6);
set('z span',3e-6);

addprofile;
set('name', 'XY-profile_monitor');
set('monitor type','2D Z-normal');
set('z', 0.3e-6);         # Center position in x-direction
set('y', 0);         # Center position in y-direction
set('y span', 5e-6); # Span in y-direction
set('x', Device_length/2);         # Center position in z-direction
set('x span', Device_length ); # Span in z-direction





