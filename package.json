{
  "name": "waferwatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "supabase": "supabase",
    "db:link": "supabase link",
    "db:push": "supabase db push",
    "db:push:dry": "supabase db push --dry-run",
    "db:types": "supabase gen types typescript --linked > src/types/database.generated.ts",
    "migration:list": "supabase migration list",
    "migration:repair": "supabase migration repair",
    "supabase:types": "supabase gen types typescript --linked > src/types/database.generated.ts",
    "wireframe:fixture": "node --env-file=.env.local scripts/wireframe-fixture.mjs",
    "wireframe:fixture:snapshot": "node --env-file=.env.local scripts/wireframe-fixture.mjs snapshot",
    "wireframe:fixture:clear": "node --env-file=.env.local scripts/wireframe-fixture.mjs clear",
    "wireframe:fixture:seed": "node --env-file=.env.local scripts/wireframe-fixture.mjs seed",
    "wireframe:fixture:verify": "node --env-file=.env.local scripts/wireframe-fixture.mjs verify",
    "deploy:preview": "npx --yes vercel",
    "deploy:prod": "npx --yes vercel --prod"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "dayjs": "^1.11.21",
    "interactjs": "^1.10.27",
    "lucide-react": "^1.23.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-calendar-timeline": "^0.30.0-beta.18",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.16",
    "supabase": "^2.106.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
